---
import ProjectLayout from '@layouts/ProjectLayout.astro';
import ProjectHero from '@components/project/ProjectHero.astro';
import ProjectTags from '@components/project/ProjectTags.astro';
import ProjectSection from '@components/project/ProjectSection.astro';
import ProjectCard from '@components/project/ProjectCard.astro';
import ProjectCompetences from '@components/project/ProjectCompetences.astro';
import image from '@assets/images/SAE3A.png';
import image2 from '@assets/images/SAEA3-agregation.png';
import { Image } from 'astro:assets';

const tags = ['Scrum Master', 'Gestion de projet', 'SAE 3A', 'IUT', 'PHP', 'PL/SQL', 'Oracle'];
const actions = [
	{
		id: 'ac1',
		title: "AC 1 : Choisir et implémenter les architectures adaptées",
		description: "Conception d'une architecture PHP + base PL/SQL Oracle structurée selon les besoins fonctionnels identifiés avec les équipes enseignantes. Choix des technologies adaptées à l'hébergement et aux contraintes de l'IUT.",
		icon: "squares-2x2"
	},
	{
		id: 'ac2',
		title: "AC 2 : Faire évoluer une application existante",
		description: "En tant que Scrum Master, pilotage de l'évolution du projet sprint après sprint : priorisation du backlog, coordination de l'équipe, adaptation des fonctionnalités aux retours des utilisateurs tout au long du développement.",
		icon: "arrow-path"
	},
	{
		id: 'ac3',
		title: "AC 3 : Intégrer des solutions dans un environnement de production",
		description: "Mise en ligne du site avec de vraies données étudiantes, validation fonctionnelle en conditions réelles et prise en compte des contraintes d'un système d'information universitaire.",
		icon: "rocket-launch"
	},
];
---

<ProjectLayout title="SAE 3A - Site d'avis | Portfolio">
	<ProjectHero
		icon="globe-alt"
		badge="Projet Universitaire"
		badgeColor="orange"
		title="SAE 3A - "
		titleHighlight="Site d'avis"
		titleHighlightColor="text-orange-500 dark:text-orange-500"
		description="Un projet collaboratif visant à créer une plateforme permettant aux étudiants de partager leurs avis sur les universités et aux professeurs d'apporter leur expertise pour guider les choix d'orientation."
	/>

	<ProjectTags tags={tags} />

	<ProjectSection
		badge="Mon rôle"
		badgeColor="blue"
		title="Scrum Master"
		centered={true}
	>
		<div class="grid lg:grid-cols-2 gap-12 items-center">
			<div class="space-y-8">
				<ProjectCard
					icon="flag"
					title="Mission principale"
					description=""
				>
					<p class="text-gray-700 dark:text-gray-300 leading-relaxed">
						En tant que <span class="font-semibold text-orange-500">Scrum Master</span>,
						ma mission était de gérer l'organisation de l'équipe, assurer une communication fluide
						entre les membres et faciliter les processus agiles.
					</p>
				</ProjectCard>

				<ProjectCard
					icon="rocket-launch"
					title="Motivation de l'équipe"
					description=""
				>
					<p class="text-gray-700 dark:text-gray-300 leading-relaxed">
						J'ai créé un environnement de travail <span class="font-semibold text-blue-600">collaboratif</span>
						en organisant des réunions régulières, définissant des rôles clairs et maintenant
						une dynamique positive pour respecter les délais.
					</p>
				</ProjectCard>
			</div>

			<div class="bg-orange-500 dark:bg-orange-600 p-8 rounded-2xl text-white shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-105">
				<h3 class="text-2xl font-bold mb-6">Activités clés</h3>
				<div class="space-y-6">
					<div class="flex items-start space-x-4">
						<div class="bg-white p-3 rounded-lg">
							<span class="text-2xl">📅</span>
						</div>
						<div>
							<h4 class="font-semibold text-lg mb-2">Daily Meetings</h4>
							<p class="text-white/90">
								Organisation de <span class="font-semibold">réunions quotidiennes</span>
								pour suivre l'avancement et identifier les blocages.
							</p>
						</div>
					</div>

					<div class="flex items-start space-x-4">
						<div class="bg-white p-3 rounded-lg">
							<span class="text-2xl">🔧</span>
						</div>
						<div>
							<h4 class="font-semibold text-lg mb-2">Résolution de problèmes</h4>
							<p class="text-white/90">
								Facilitation de la <span class="font-semibold">résolution des blocages</span>
								en mobilisant les ressources nécessaires.
							</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</ProjectSection>

	<ProjectSection
		badge="Résultats du projet"
		badgeColor="purple"
		centered={true}
	>
		<div class="grid md:grid-cols-2 gap-6">
			<div class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300">
				<Image
					src={image}
					alt="Agrégation des données du projet SAE 3A"
					class="rounded-xl shadow-lg w-full h-auto"
					format="png"
					width={600}
					height={400}
					loading="lazy"
				/>
			</div>
			<div class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300">
				<Image
					src={image2}
					alt="Agrégation des données du projet SAE 3A"
					class="rounded-xl shadow-lg w-full h-auto"
					format="png"
					width={600}
					height={400}
					loading="lazy"
				/>
			</div>
		</div>
	</ProjectSection>

	<ProjectCompetences
		badge="Compétences acquises"
		badgeColor="green"
		title="Apprentissages Critiques"
		subtitle='Compétence <span class="font-semibold text-orange-500">Réaliser</span> — Niveau 3 : Adapter des applications sur un ensemble de supports'
		competences={actions}
		accentColor="orange-500"
	/>
</ProjectLayout>
