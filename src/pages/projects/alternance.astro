---
import ProjectLayout from '@layouts/ProjectLayout.astro';
import ProjectHero from '@components/project/ProjectHero.astro';
import ProjectTags from '@components/project/ProjectTags.astro';
import ProjectSection from '@components/project/ProjectSection.astro';
import ProjectCompetences from '@components/project/ProjectCompetences.astro';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import imgAlternance1 from '@assets/images/alternance1.png';
import imgOpenapi from '@assets/images/openapi.png';

const tags = ['PHP', 'Vue.js', 'API REST', 'OpenAPI', 'Swagger', 'GitLab CI', 'ESX', 'Hyper-V', 'Testing', 'MFA', 'JWT'];

const competences = [
    {
        id: 'ac1',
        title: "AC 1 : Choisir et implémenter les architectures adaptées",
        description: "Acquis — J'ai choisi et mis en place toute la structure du code, en restructurant complètement les dossiers et en implémentant les namespaces pour organiser le projet de manière claire et maintenable. J'ai également implémenté le MFA et intégré le front avec Vue.js. Exemples concrets : restructuration des dossiers, implémentation des namespaces, choix de l'architecture, implémentation du MFA.",
        icon: "squares-2x2"
    },
    {
        id: 'ac2',
        title: "AC 2 : Faire évoluer une application existante",
        description: "Acquis — J'ai ajouté des fonctionnalités au site existant, corrigé des bugs et refactorisé le code pour améliorer la qualité et la maintenance. J'ai créé des services dédiés, comme UtilisateurService, pour isoler la logique métier et faciliter les évolutions futures. Exemples concrets : refactorisation du code, ajout de fonctionnalités utilisateurs, amélioration de la documentation.",
        icon: "arrow-path"
    },
    {
        id: 'ac3',
        title: "AC 3 : Intégrer des solutions dans un environnement de production",
        description: "En cours — J'ai participé au déploiement et utilisé Git et CI/CD pour préparer les mises en production. J'ai appris à adapter le code aux contraintes réelles : performance, sécurité et compatibilité. Exemples concrets : déploiement supervisé, tests de non-régression avant mise en ligne, ajustements backend pour la prod.",
        icon: "rocket-launch"
    }
];
---

<ProjectLayout title="Alternance - Développeur Front/Back-end | Portfolio">
    <ProjectHero
        icon="briefcase"
        badge="Alternance Professionnelle • Septembre 2025 - Mars 2026"
        badgeColor="blue"
        title="Mission 1 — Développement "
        titleHighlight="Web & QA"
        titleHighlightColor="text-blue-500 dark:text-blue-500"
        description="Contribution au développement d'un système de gestion de sauvegarde de données pour entreprises. De la phase de tests fonctionnels jusqu'à la sortie de la V1 le 16 mars 2026."
    />

    <ProjectTags tags={tags} />

    <!-- Contexte -->
    <ProjectSection
        badge="Contexte"
        badgeColor="purple"
        title="Le Projet BeeBox"
        centered={true}
    >
        <div class="grid lg:grid-cols-2 gap-10">
            <div class="bg-white dark:bg-gray-800 p-8 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-105">
                <div class="flex items-center mb-5">
                    <div class="w-12 h-12 flex items-center justify-center rounded-lg bg-purple-100 dark:bg-purple-900/30 mr-4">
                        <Icon name="heroicons:server-stack" class="w-7 h-7 text-purple-600 dark:text-purple-400" />
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100">La solution</h3>
                </div>
                <p class="text-gray-700 dark:text-gray-300 leading-relaxed mb-4">
                    <span class="font-semibold text-blue-600">BeeBox</span> est un boîtier physique livré aux entreprises pour gérer leurs sauvegardes de données. Le boîtier héberge un serveur de sauvegarde et un site web de gestion.
                </p>
                <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
                    Le site permet de configurer les agents de sauvegarde (machines Windows/Linux, VMs ESX, Hyper-V, bases de données), de planifier des sauvegardes, de les surveiller, et de restaurer des fichiers ou des VMs complètes.
                </p>
            </div>

            <div class="bg-white dark:bg-gray-800 p-8 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-105">
                <div class="flex items-center mb-5">
                    <div class="w-12 h-12 flex items-center justify-center rounded-lg bg-blue-100 dark:bg-blue-900/30 mr-4">
                        <Icon name="heroicons:users" class="w-7 h-7 text-blue-600 dark:text-blue-400" />
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100">Mon rôle dans l'équipe</h3>
                </div>
                <p class="text-gray-700 dark:text-gray-300 leading-relaxed mb-4">
                    Intégration dans une équipe de <span class="font-semibold text-blue-600">développeurs en méthode agile (Scrum)</span>. Participation aux daily meetings, sprints de 2 semaines, et revues de code sur GitLab.
                </p>
                <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
                    Stack technique : backend en <span class="font-semibold text-purple-600">PHP</span> communiquant avec le serveur de sauvegarde, frontend en <span class="font-semibold text-green-600">Vue.js</span>, tickets gérés sur <span class="font-semibold">Jira</span>, CI/CD sur <span class="font-semibold">GitLab</span>.
                </p>
            </div>
        </div>
    </ProjectSection>

    <!-- Timeline -->
    <ProjectSection
        badge="Déroulement"
        badgeColor="orange"
        title="Chronologie de la mission"
        centered={true}
    >
        <div class="max-w-3xl mx-auto space-y-0">
            <!-- Phase 1 -->
            <div class="flex gap-6">
                <div class="flex flex-col items-center">
                    <div class="w-12 h-12 rounded-full bg-orange-500 flex items-center justify-center flex-shrink-0 shadow-lg">
                        <Icon name="heroicons:clipboard-document-list" class="w-6 h-6 text-white" />
                    </div>
                    <div class="w-0.5 flex-1 bg-gray-200 dark:bg-gray-700 mt-2"></div>
                </div>
                <div class="pb-10 pt-1 flex-1">
                    <p class="text-sm font-medium text-orange-500 mb-1">Septembre 2025</p>
                    <h4 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-2">Phase de tests & Découverte</h4>
                    <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
                        Déroulement complet des cas de tests fonctionnels conçus par le testeur logiciel. Couverture de toutes les fonctionnalités : administration, backupsets, partages, restauration VM, Business Continuity. Formation SMSI MOOC ANSSI. Cette phase m'a permis de comprendre le métier de la sauvegarde avant de toucher au code.
                    </p>
                </div>
            </div>

            <!-- Phase 2 -->
            <div class="flex gap-6">
                <div class="flex flex-col items-center">
                    <div class="w-12 h-12 rounded-full bg-blue-500 flex items-center justify-center flex-shrink-0 shadow-lg">
                        <Icon name="heroicons:code-bracket-square" class="w-6 h-6 text-white" />
                    </div>
                    <div class="w-0.5 flex-1 bg-gray-200 dark:bg-gray-700 mt-2"></div>
                </div>
                <div class="pb-10 pt-1 flex-1">
                    <p class="text-sm font-medium text-blue-500 mb-1">Octobre — Novembre 2025</p>
                    <h4 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-2">Développement & Corrections</h4>
                    <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
                        Résolution de bugs front-end Vue.js et de logique métier backend PHP. Refonte de la logique d'affichage conditionnel pour les plugins ESX et Hyper-V. Chaque vendredi : présentation d'un design pattern à l'équipe (Factory, Prototype).
                    </p>
                </div>
            </div>

            <!-- Phase 3 -->
            <div class="flex gap-6">
                <div class="flex flex-col items-center">
                    <div class="w-12 h-12 rounded-full bg-red-500 flex items-center justify-center flex-shrink-0 shadow-lg">
                        <Icon name="heroicons:magnifying-glass" class="w-6 h-6 text-white" />
                    </div>
                    <div class="w-0.5 flex-1 bg-gray-200 dark:bg-gray-700 mt-2"></div>
                </div>
                <div class="pb-10 pt-1 flex-1">
                    <p class="text-sm font-medium text-red-500 mb-1">Novembre 2025 — Semaine du 24</p>
                    <h4 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-2">Phase de test pré-bêta intensive</h4>
                    <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
                        Semaine intensive sous forte pression (DT, PO, direction, commerciaux). 70% des tests terminés en fin de semaine. 40 tickets remontés, triés par criticité : 8 bloqueurs, 7 critiques, 9 majeures. Les bugs bloqueurs et critiques intègrent directement le sprint en cours pour correction immédiate.
                    </p>
                </div>
            </div>

            <!-- Phase 4 -->
            <div class="flex gap-6">
                <div class="flex flex-col items-center">
                    <div class="w-12 h-12 rounded-full bg-purple-500 flex items-center justify-center flex-shrink-0 shadow-lg">
                        <Icon name="heroicons:wrench-screwdriver" class="w-6 h-6 text-white" />
                    </div>
                    <div class="w-0.5 flex-1 bg-gray-200 dark:bg-gray-700 mt-2"></div>
                </div>
                <div class="pb-10 pt-1 flex-1">
                    <p class="text-sm font-medium text-purple-500 mb-1">Décembre 2025 — Février 2026</p>
                    <h4 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-2">Refactorisation & Gestion des utilisateurs</h4>
                    <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
                        Refonte complète de l'architecture de l'API PHP : nouvelles normes de code, suppression des stdClass au profit de classes typées. Implémentation de la gestion des utilisateurs (création, modification, suppression, validation) avec refresh token. Mise en place d'une documentation Swagger/OpenAPI automatisée via CI GitLab. Présentation du pattern Iterator à l'équipe.
                    </p>
                </div>
            </div>

            <!-- Phase 5 : V1 -->
            <div class="flex gap-6">
                <div class="flex flex-col items-center">
                    <div class="w-12 h-12 rounded-full bg-green-500 flex items-center justify-center flex-shrink-0 shadow-lg">
                        <Icon name="heroicons:rocket-launch" class="w-6 h-6 text-white" />
                    </div>
                </div>
                <div class="pb-2 pt-1 flex-1">
                    <p class="text-sm font-medium text-green-500 mb-1">Mars 2026 — V1 le 16/03/2026</p>
                    <h4 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-2">MFA & Sortie de la V1</h4>
                    <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
                        Développement complet du MFA (authentification à 2 facteurs) côté backend en 2 jours avec le tech lead, correction des bugs remontés par le testeur en 1 jour. Côté frontend : activation du MFA pour toute la box par le superAdmin. Nouveau système de notifications. La <span class="font-semibold text-green-600">V1 est sortie le 16 mars 2026</span>.
                    </p>
                </div>
            </div>
        </div>
    </ProjectSection>

    <!-- Refactorisation API -->
    <ProjectSection
        badge="Refactorisation"
        badgeColor="purple"
        title="Refonte de l'API & Gestion des utilisateurs"
        centered={true}
    >
        <div class="space-y-8 max-w-5xl mx-auto">
            <!-- Contexte refacto -->
            <div class="bg-white dark:bg-gray-800 p-8 rounded-2xl shadow-lg">
                <div class="flex items-center mb-5">
                    <div class="w-12 h-12 flex items-center justify-center rounded-lg bg-purple-100 dark:bg-purple-900/30 mr-4">
                        <Icon name="heroicons:wrench-screwdriver" class="w-7 h-7 text-purple-600 dark:text-purple-400" />
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100">Contexte de la refactorisation</h3>
                </div>
                <p class="text-gray-700 dark:text-gray-300 leading-relaxed mb-4">
                    Avec l'arrivée d'un nouveau chef de projet focalisé sur l'évolution du serveur de sauvegarde, il a fallu <span class="font-semibold text-purple-600">revoir l'architecture de l'API PHP</span> pour faciliter les futures intégrations et passer aux prochaines versions plus facilement.
                </p>
                <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
                    La refonte a porté sur l'organisation des dossiers, l'introduction de <span class="font-semibold">normes PHP strictes</span> (typage, classes dédiées en remplacement des <code class="bg-gray-100 dark:bg-gray-700 px-1.5 py-0.5 rounded text-sm">stdClass</code>), et la mise en place d'une couche d'abstraction propre entre le frontend et le serveur de sauvegarde.
                </p>
            </div>

            <!-- Gestion users + refresh token -->
            <div class="grid md:grid-cols-2 gap-6">
                <div class="bg-white dark:bg-gray-800 p-8 rounded-2xl shadow-lg">
                    <div class="flex items-center mb-5">
                        <div class="w-12 h-12 flex items-center justify-center rounded-lg bg-blue-100 dark:bg-blue-900/30 mr-4">
                            <Icon name="heroicons:user-group" class="w-7 h-7 text-blue-600 dark:text-blue-400" />
                        </div>
                        <h3 class="text-lg font-bold text-gray-900 dark:text-gray-100">Gestion des utilisateurs</h3>
                    </div>
                    <p class="text-gray-700 dark:text-gray-300 leading-relaxed text-sm mb-4">
                        Implémentation complète des routes CRUD vers le serveur de sauvegarde : création, modification, suppression, validation et récupération d'utilisateurs. J'ai fait le lien entre ce que renvoyait le serveur et ce que le frontend attendait, en agissant comme une véritable passerelle.
                    </p>
                    <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400">
                        <li class="flex items-center gap-2"><span class="text-green-500 font-bold">GET</span> Récupération d'un ou plusieurs utilisateurs</li>
                        <li class="flex items-center gap-2"><span class="text-blue-500 font-bold">POST</span> Création & validation de compte</li>
                        <li class="flex items-center gap-2"><span class="text-orange-500 font-bold">PATCH</span> Modification (mot de passe, rôle...)</li>
                        <li class="flex items-center gap-2"><span class="text-red-500 font-bold">DELETE</span> Suppression d'utilisateur</li>
                    </ul>
                </div>

                <div class="bg-white dark:bg-gray-800 p-8 rounded-2xl shadow-lg">
                    <div class="flex items-center mb-5">
                        <div class="w-12 h-12 flex items-center justify-center rounded-lg bg-green-100 dark:bg-green-900/30 mr-4">
                            <Icon name="heroicons:key" class="w-7 h-7 text-green-600 dark:text-green-400" />
                        </div>
                        <h3 class="text-lg font-bold text-gray-900 dark:text-gray-100">Refresh Token</h3>
                    </div>
                    <p class="text-gray-700 dark:text-gray-300 leading-relaxed text-sm mb-4">
                        Mise en place d'un système de <span class="font-semibold text-green-600">refresh token</span> pour la gestion des sessions utilisateurs. L'access token de courte durée est renouvelé automatiquement via le refresh token sans que l'utilisateur ait à se reconnecter.
                    </p>
                    <div class="bg-gray-50 dark:bg-gray-700 rounded-xl p-4 space-y-2 text-xs font-mono text-gray-600 dark:text-gray-300">
                        <div class="flex items-center gap-2">
                            <span class="w-2 h-2 rounded-full bg-green-400 flex-shrink-0"></span>
                            <span>Access token — courte durée</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="w-2 h-2 rounded-full bg-blue-400 flex-shrink-0"></span>
                            <span>Refresh token — longue durée</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="w-2 h-2 rounded-full bg-purple-400 flex-shrink-0"></span>
                            <span>Renouvellement automatique transparent</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </ProjectSection>

    <!-- Preuves de réalisation -->
    <ProjectSection
        badge="Preuves de réalisation"
        badgeColor="blue"
        title="Fonctionnalités clés"
        centered={true}
    >
        <div class="space-y-10 max-w-5xl mx-auto">
            <!-- Placeholder image interface -->
            <div class="bg-white dark:bg-gray-800 p-8 rounded-2xl shadow-lg">
                <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2">Interface de l'application</h3>
                <p class="text-gray-600 dark:text-gray-400 text-sm mb-6">
                    Vue générale du site web de gestion de la BeeBox avec ses différentes sections (backupsets, partages, administration).
                </p>
                <div class="bg-gray-100 dark:bg-gray-700 rounded-xl overflow-hidden">
                    <Image
                        src={imgAlternance1}
                        alt="Interface de l'application BeeBox"
                        class="rounded-xl w-full h-auto object-cover"
                        format="png"
                        width={900}
                        height={500}
                        loading="eager"
                    />
                </div>
            </div>

            <!-- MFA -->
            <div class="bg-white dark:bg-gray-800 p-8 rounded-2xl shadow-lg">
                <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2">Authentification MFA</h3>
                <p class="text-gray-600 dark:text-gray-400 text-sm mb-6">
                    Quand le superAdmin active le MFA pour toute la box, il doit d'abord configurer le sien pour prouver qu'il peut le faire. Ensuite, chaque utilisateur configure le sien à sa prochaine connexion.
                </p>
                <div class="grid md:grid-cols-3 gap-4">
                    <div class="bg-blue-50 dark:bg-blue-900/20 rounded-xl p-5 text-center">
                        <Icon name="heroicons:adjustments-horizontal" class="w-10 h-10 text-blue-600 mx-auto mb-3" />
                        <h4 class="font-bold text-gray-900 dark:text-gray-100 mb-2 text-sm">1. Activation globale</h4>
                        <p class="text-xs text-gray-600 dark:text-gray-400">Le superAdmin active le MFA pour toute la box via la page d'administration</p>
                    </div>
                    <div class="bg-purple-50 dark:bg-purple-900/20 rounded-xl p-5 text-center">
                        <Icon name="heroicons:device-phone-mobile" class="w-10 h-10 text-purple-600 mx-auto mb-3" />
                        <h4 class="font-bold text-gray-900 dark:text-gray-100 mb-2 text-sm">2. Vérification superAdmin</h4>
                        <p class="text-xs text-gray-600 dark:text-gray-400">Il configure son propre MFA (QR code, code TOTP) avant validation</p>
                    </div>
                    <div class="bg-green-50 dark:bg-green-900/20 rounded-xl p-5 text-center">
                        <Icon name="heroicons:check-circle" class="w-10 h-10 text-green-600 mx-auto mb-3" />
                        <h4 class="font-bold text-gray-900 dark:text-gray-100 mb-2 text-sm">3. Déploiement progressif</h4>
                        <p class="text-xs text-gray-600 dark:text-gray-400">Chaque utilisateur configure son MFA à sa prochaine connexion</p>
                    </div>
                </div>
            </div>

            <!-- Documentation Swagger -->
            <div class="bg-white dark:bg-gray-800 p-8 rounded-2xl shadow-lg">
                <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2">Documentation API automatisée</h3>
                <p class="text-gray-600 dark:text-gray-400 text-sm mb-6">
                    Pipeline GitLab CI qui génère la documentation Swagger à chaque push sur la branche dev et la publie automatiquement sur GitLab Pages.
                </p>
                <div class="bg-gray-100 dark:bg-gray-700 rounded-xl overflow-hidden">
                    <Image
                        src={imgOpenapi}
                        alt="Documentation OpenAPI générée automatiquement"
                        class="rounded-xl w-full h-auto object-cover"
                        format="png"
                        width={900}
                        height={500}
                        loading="eager"
                    />
                </div>
            </div>
        </div>
    </ProjectSection>

    <!-- Bilan -->
    <ProjectSection centered={true}>
        <div class="bg-gradient-to-br from-blue-500 to-purple-600 p-8 rounded-2xl text-white shadow-lg max-w-4xl mx-auto">
            <div class="text-center mb-8">
                <div class="w-16 h-16 flex items-center justify-center rounded-2xl bg-white/20 mx-auto mb-4">
                    <Icon name="heroicons:academic-cap" class="w-10 h-10 text-white" />
                </div>
                <h2 class="font-monospace text-3xl mb-2">Bilan de la Mission 1</h2>
                <div class="flex flex-wrap justify-center gap-4 mt-4">
                    <a href="/Portfolio-BUT/projects/alternance-dockerisation" class="bg-white/20 hover:bg-white/30 transition px-5 py-2 rounded-xl text-sm font-semibold backdrop-blur-sm">
                        Voir Mission 2 : Dockerisation →
                    </a>
                </div>
            </div>
            <div class="space-y-4">
                <p class="text-white/90 leading-relaxed">
                    Cette mission m'a fait vivre le cycle complet d'un projet logiciel professionnel : compréhension du métier par les tests, contribution aux fonctionnalités, pression de la deadline, sortie d'une V1. La phase de test intensive de novembre 2025 a été particulièrement formatrice : gérer des bugs critiques sous pression tout en maintenant la qualité, c'est une expérience qu'on n'apprend pas en cours.
                </p>
                <p class="text-white/90 leading-relaxed">
                    La refonte de l'API m'a sensibilisé à l'importance de la <span class="font-semibold">qualité du code sur le long terme</span> : supprimer les stdClass, typer les retours, structurer les dossiers — ce sont des décisions qui semblent coûteuses à court terme mais qui ont rendu l'implémentation de la gestion des utilisateurs et du MFA beaucoup plus claire.
                </p>
                <div class="grid grid-cols-3 gap-4 mt-6">
                    <div class="text-center bg-white/10 rounded-xl p-4">
                        <div class="text-2xl font-bold">4</div>
                        <div class="text-xs text-white/80">Routes CRUD<br/>implémentées</div>
                    </div>
                    <div class="text-center bg-white/10 rounded-xl p-4">
                        <div class="text-2xl font-bold">16/03</div>
                        <div class="text-xs text-white/80">V1 livrée</div>
                    </div>
                    <div class="text-center bg-white/10 rounded-xl p-4">
                        <div class="text-2xl font-bold">6 mois</div>
                        <div class="text-xs text-white/80">Septembre → Mars</div>
                    </div>
                </div>
            </div>
        </div>
    </ProjectSection>

    <ProjectCompetences
        badge="Compétences"
        badgeColor="blue"
        title="Apprentissages Critiques"
        subtitle='Compétence <span class="font-semibold text-blue-600">Réaliser</span> — Niveau 3 : Adapter des applications sur un ensemble de supports'
        competences={competences}
        accentColor="blue-500"
    />
</ProjectLayout>
