---
import ProjectLayout from '@layouts/ProjectLayout.astro';
import ProjectHero from '@components/project/ProjectHero.astro';
import ProjectTags from '@components/project/ProjectTags.astro';
import ProjectSection from '@components/project/ProjectSection.astro';
import ProjectCard from '@components/project/ProjectCard.astro';
import ProjectCompetences from '@components/project/ProjectCompetences.astro';
import imageAvant from '@assets/images/avantstage.png';
import image from '@assets/images/stage.png';
import { Image } from 'astro:assets';

const tags = ['PHP', 'MySQL', 'phpMyAdmin', 'OVH', 'Stage'];
const actions = [
    {
        id: 'ac1',
        title: "AC 1 : Choisir et implémenter les architectures adaptées",
        description: "Analyse de l'architecture PHP/MySQL existante et identification des choix techniques pour améliorer la solution : organisation du code, structure de la base, compatibilité avec l'hébergement OVH et les contraintes du client.",
        icon: "squares-2x2"
    },
    {
        id: 'ac2',
        title: "AC 2 : Faire évoluer une application existante",
        description: "Amélioration d'un site de réservation en production : nouvelles fonctionnalités, refonte de l'interface, optimisation des requêtes MySQL, tout en préservant le fonctionnement pour les utilisateurs existants (directeurs, personnels).",
        icon: "arrow-path"
    },
    {
        id: 'ac3',
        title: "AC 3 : Intégrer des solutions dans un environnement de production",
        description: "Déploiement sur serveur OVH, configuration de la base MySQL en production, validation avec les utilisateurs finaux et gestion des ajustements post-déploiement.",
        icon: "rocket-launch"
    },
];
---

<ProjectLayout title="Stage - Réservation Cantine | Portfolio">
    <ProjectHero
        icon="cake"
        badge="Stage Professionnel"
        badgeColor="green"
        title="Stage - "
        titleHighlight="Réservation Cantine"
        titleHighlightColor="text-green-500 dark:text-green-500"
        description="Amélioration d'un système de réservation de cantine pour écoles privées. Développement en PHP avec une base de données MySQL, hébergement sur serveur OVH/O2Switch."
    />

    <ProjectTags tags={tags} />

    <ProjectSection
        badge="Mon rôle"
        badgeColor="purple"
        title="Développeur Web"
    >
        <div class="grid lg:grid-cols-2 gap-12 items-center">
            <div class="space-y-8">
                <ProjectCard
                    icon="flag"
                    title="Mission principale"
                    description=""
                >
                    <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
                        Collaborer avec mon <span class="font-semibold text-green-500">maître de stage</span>
                        pour améliorer l'interface utilisateur et les fonctionnalités du site de réservation,
                        tout en maintenant une communication directe avec les clients.
                    </p>
                </ProjectCard>

                <ProjectCard
                    icon="rocket-launch"
                    title="Approche client"
                    description=""
                >
                    <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
                        Nous avons organisé des <span class="font-semibold text-purple-600">rendez-vous réguliers</span>
                        avec les clients pour comprendre leurs besoins spécifiques et adapter les solutions
                        aux contraintes des écoles privées.
                    </p>
                </ProjectCard>
            </div>

            <div class="bg-green-500 dark:bg-green-600 p-8 rounded-2xl text-white shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-105">
                <h3 class="text-2xl font-bold mb-6">Technologies utilisées</h3>
                <div class="space-y-6">
                    <div class="flex items-start space-x-4">
                        <div class="bg-white p-3 rounded-lg">
                            <span class="text-2xl">🐘</span>
                        </div>
                        <div>
                            <h4 class="font-semibold text-lg mb-2">PHP & MySQL</h4>
                            <p class="text-white/90">
                                Développement en <span class="font-semibold">PHP natif</span>
                                avec gestion de base de données MySQL via phpMyAdmin.
                            </p>
                        </div>
                    </div>

                    <div class="flex items-start space-x-4">
                        <div class="bg-white p-3 rounded-lg">
                            <span class="text-2xl">🌐</span>
                        </div>
                        <div>
                            <h4 class="font-semibold text-lg mb-2">Hébergement</h4>
                            <p class="text-white/90">
                                Déploiement sur serveur <span class="font-semibold">OVH/O2Switch</span>
                                avec configuration et maintenance de l'environnement.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </ProjectSection>

    <ProjectSection
        badge="Transformation du site"
        badgeColor="orange"
        centered={true}
    >
        <div class="grid lg:grid-cols-2 gap-12">
            <!-- Avant -->
            <div class="bg-white dark:bg-gray-800 p-8 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300">
                <h3 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6 text-center">
                    🔴 Avant
                </h3>
                <div class="bg-gray-100 dark:bg-gray-700 rounded-xl overflow-hidden mb-6">
                    <Image
                        src={imageAvant}
                        alt="Image du projet de stage avant"
                        class="rounded-xl w-full h-auto object-cover"
                        format="png"
                        width={500}
                        height={500}
                        loading="eager"
                    />
                </div>
                <ul class="space-y-3 text-gray-700 dark:text-gray-300">
                    <li class="flex items-center space-x-3">
                        <span class="text-red-500">❌</span>
                        <span>Interface peu intuitive</span>
                    </li>
                    <li class="flex items-center space-x-3">
                        <span class="text-red-500">❌</span>
                        <span>Design obsolète</span>
                    </li>
                    <li class="flex items-center space-x-3">
                        <span class="text-red-500">❌</span>
                        <span>Fonctionnalités limitées</span>
                    </li>
                </ul>
            </div>

            <!-- Après -->
            <div class="bg-white dark:bg-gray-800 p-8 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300">
                <h3 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6 text-center">
                    🟢 Après
                </h3>
                <div class="bg-gray-100 dark:bg-gray-700 rounded-xl overflow-hidden mb-6">
                    <Image
                        src={image}
                        alt="Image du projet de stage après"
                        class="rounded-xl w-full h-auto object-cover"
                        format="png"
                        width={500}
                        height={500}
                        loading="eager"
                    />
                </div>
                <ul class="space-y-3 text-gray-700 dark:text-gray-300">
                    <li class="flex items-center space-x-3">
                        <span class="text-green-500">✅</span>
                        <span>Interface moderne et intuitive</span>
                    </li>
                    <li class="flex items-center space-x-3">
                        <span class="text-green-500">✅</span>
                        <span>Design responsive adaptatif</span>
                    </li>
                    <li class="flex items-center space-x-3">
                        <span class="text-green-500">✅</span>
                        <span>Nouvelles fonctionnalités</span>
                    </li>
                </ul>
            </div>
        </div>
    </ProjectSection>

    <ProjectSection
        badge="Gestion de la base de données"
        badgeColor="blue"
        centered={true}
    >
        <div class="bg-white dark:bg-gray-800 p-8 rounded-2xl shadow-lg max-w-4xl mx-auto">
            <h3 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6 text-center">
                Optimisation MySQL
            </h3>

            <div class="grid md:grid-cols-2 gap-8 text-left">
                <div class="space-y-4">
                    <h4 class="font-semibold text-lg text-gray-900 dark:text-gray-100">Modifications apportées :</h4>
                    <ul class="space-y-2 text-gray-700 dark:text-gray-300">
                        <li class="flex items-center space-x-2">
                            <span class="text-green-500">•</span>
                            <span>Ajout de nouvelles tables</span>
                        </li>
                        <li class="flex items-center space-x-2">
                            <span class="text-green-500">•</span>
                            <span>Optimisation des requêtes</span>
                        </li>
                        <li class="flex items-center space-x-2">
                            <span class="text-green-500">•</span>
                            <span>Restructuration des relations</span>
                        </li>
                    </ul>
                </div>
                <div class="space-y-4">
                    <h4 class="font-semibold text-lg text-gray-900 dark:text-gray-100">Outils utilisés :</h4>
                    <ul class="space-y-2 text-gray-700 dark:text-gray-300">
                        <li class="flex items-center space-x-2">
                            <span class="text-blue-500">•</span>
                            <span>phpMyAdmin</span>
                        </li>
                        <li class="flex items-center space-x-2">
                            <span class="text-blue-500">•</span>
                            <span>MySQL Workbench</span>
                        </li>
                        <li class="flex items-center space-x-2">
                            <span class="text-blue-500">•</span>
                            <span>Scripts SQL personnalisés</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </ProjectSection>

    <ProjectCompetences
        badge="Compétences acquises"
        badgeColor="indigo"
        title="Apprentissages du Stage"
        subtitle='Compétence <span class="font-semibold text-green-600">Réaliser</span> — Niveau 3 : Adapter des applications sur un ensemble de supports'
        competences={actions}
        accentColor="green-500"
    />
</ProjectLayout>
