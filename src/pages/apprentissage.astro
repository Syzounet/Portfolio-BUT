---
import Layout from '@layouts/Layout.astro';
import Contact from '@components/Contact.astro';
import BackToTop from '@components/ui/BackToTop.astro';

const niveaux = {
    acquis:   { label: 'Acquis',    color: 'bg-green-500',  text: 'text-green-700 dark:text-green-300',  bg: 'bg-green-50 dark:bg-green-900/20',  border: 'border-green-200 dark:border-green-800' },
    enCours:  { label: 'En cours',  color: 'bg-yellow-500', text: 'text-yellow-700 dark:text-yellow-300', bg: 'bg-yellow-50 dark:bg-yellow-900/20', border: 'border-yellow-200 dark:border-yellow-800' },
    debutant: { label: 'Débutant',  color: 'bg-red-400',    text: 'text-red-700 dark:text-red-300',      bg: 'bg-red-50 dark:bg-red-900/20',      border: 'border-red-200 dark:border-red-800' },
};

const competences = [
    {
        num: 1,
        nom: "Réaliser",
        niveau: "Niveau 3 — Adapter des applications sur un ensemble de supports (embarqué, web, mobile, IoT...)",
        color: "orange",
        badgeClass: "bg-orange-500 dark:bg-orange-600",
        borderClass: "border-orange-400",
        acs: [
            {
                id: "AC31.01",
                titre: "Choisir et implémenter les architectures adaptées",
                niveau: niveaux.acquis,
                description: "J'ai choisi et mis en place toute la structure du code, en restructurant complètement les dossiers et en implémentant les namespaces pour organiser le projet de manière claire et maintenable. J'ai également implémenté le MFA et intégré le front avec Vue.js.",
                projets: [{ label: "Alternance Mission 1", url: "/Portfolio-BUT/projects/alternance" }]
            },
            {
                id: "AC31.02",
                titre: "Faire évoluer une application existante",
                niveau: niveaux.acquis,
                description: "J'ai ajouté des fonctionnalités au site existant, corrigé des bugs et refactorisé le code pour améliorer la qualité et la maintenance. J'ai créé des services dédiés (UtilisateurService) pour isoler la logique métier. Sur le stage, j'ai amélioré un site de réservation en production en préservant les fonctionnalités existantes.",
                projets: [
                    { label: "Alternance Mission 1", url: "/Portfolio-BUT/projects/alternance" },
                    { label: "Stage WebMinit34", url: "/Portfolio-BUT/projects/stage" },
                ]
            },
            {
                id: "AC31.03",
                titre: "Intégrer des solutions dans un environnement de production",
                niveau: niveaux.enCours,
                description: "J'ai participé au déploiement et utilisé Git et CI/CD pour préparer les mises en production. J'ai appris à adapter le code aux contraintes réelles (performance, sécurité, compatibilité). Déploiement supervisé sur serveur OVH lors du stage.",
                projets: [
                    { label: "Alternance Mission 1", url: "/Portfolio-BUT/projects/alternance" },
                    { label: "Stage WebMinit34", url: "/Portfolio-BUT/projects/stage" },
                ]
            },
        ]
    },
    {
        num: 2,
        nom: "Optimiser",
        niveau: "Niveau 3 — Analyser et optimiser des applications",
        color: "blue",
        badgeClass: "bg-blue-600 dark:bg-blue-700",
        borderClass: "border-blue-400",
        acs: [
            {
                id: "AC32.01",
                titre: "Anticiper les résultats de diverses métriques",
                niveau: niveaux.debutant,
                description: "Compétence peu développée dans mes projets actuels. L'analyse de métriques (temps d'instruction, occupation mémoire) n'a pas encore été un axe central de mes réalisations.",
                projets: []
            },
            {
                id: "AC32.02",
                titre: "Profiler, analyser et justifier le comportement d'un code exécutant",
                niveau: niveaux.enCours,
                description: "Lors de l'alternance, participation à une campagne de tests Valgrind sur le serveur de sauvegarde pour détecter les fuites mémoire. Analyse de comportements inattendus côté frontend Vue.js (watch manquant, v-if absent) lors de la correction de régressions.",
                projets: [{ label: "Alternance Mission 1", url: "/Portfolio-BUT/projects/alternance" }]
            },
            {
                id: "AC32.03",
                titre: "Choisir et utiliser des bibliothèques et méthodes dédiées",
                niveau: niveaux.enCours,
                description: "Compétence en cours de développement. Utilisation de bibliothèques existantes (Composer, OpenAPI) sans avoir encore mené d'analyse comparative approfondie des alternatives.",
                projets: []
            },
        ]
    },
    {
        num: 3,
        nom: "Administrer",
        niveau: "Niveau 3 — Faire évoluer et maintenir un système",
        color: "cyan",
        badgeClass: "bg-cyan-600 dark:bg-cyan-700",
        borderClass: "border-cyan-400",
        acs: [
            {
                id: "AC33.01",
                titre: "Créer des processus de traitement automatisés",
                niveau: niveaux.acquis,
                description: "Mise en place d'un environnement Docker entièrement automatisé pour déployer PHP 7.4 sur Debian 10 : Dockerfile paramétrable, docker-compose.yml, fichier .env dynamique. Le déploiement sur une nouvelle box est reproductible sans intervention manuelle. CI GitLab pour la génération et publication automatique de la documentation Swagger.",
                projets: [
                    { label: "Alternance Dockerisation", url: "/Portfolio-BUT/projects/alternance-dockerisation" },
                    { label: "Alternance Mission 1", url: "/Portfolio-BUT/projects/alternance" },
                ]
            },
            {
                id: "AC33.02",
                titre: "Configurer un système (performance, sécurité, compatibilité)",
                niveau: niveaux.enCours,
                description: "Configuration d'une architecture multi-couches (Apache natif → Docker → services natifs) avec gestion des contraintes de compatibilité librairies entre distributions Linux. Résolution de 5 problèmes de configuration et de compatibilité système.",
                projets: [{ label: "Alternance Dockerisation", url: "/Portfolio-BUT/projects/alternance-dockerisation" }]
            },
        ]
    },
    {
        num: 4,
        nom: "Conduire",
        niveau: "Niveau 3 — Participer à la conception et à la mise en œuvre d'un projet système d'information",
        color: "purple",
        badgeClass: "bg-purple-600 dark:bg-purple-700",
        borderClass: "border-purple-400",
        acs: [
            {
                id: "AC34.01",
                titre: "Mesurer les impacts économiques, sociétaux et technologiques d'un projet informatique",
                niveau: niveaux.enCours,
                description: "En alternance, prise de conscience des impacts d'une V1 sur les clients (box livrées, données sauvegardées). Formation SMSI MOOC ANSSI sur les enjeux de la sécurité de l'information dans les organisations.",
                projets: [{ label: "Alternance Mission 1", url: "/Portfolio-BUT/projects/alternance" }]
            },
            {
                id: "AC34.02",
                titre: "Savoir intégrer un projet informatique dans le système d'information d'une organisation",
                niveau: niveaux.acquis,
                description: "Sur la SAE3A, intégration d'une plateforme dans le SI de l'IUT. Sur le stage, intégration d'un système de réservation dans l'organisation d'écoles privées. Dans les deux cas, compréhension des processus métier existants avant de développer.",
                projets: [
                    { label: "SAE3A", url: "/Portfolio-BUT/projects/SAE3A" },
                    { label: "Stage WebMinit34", url: "/Portfolio-BUT/projects/stage" },
                ]
            },
            {
                id: "AC34.03",
                titre: "Savoir adapter un système d'information",
                niveau: niveaux.enCours,
                description: "En alternance, adaptation continue de l'API et de l'interface en fonction des évolutions du serveur de sauvegarde et des besoins des clients. Refonte de l'architecture pour faciliter les futures évolutions.",
                projets: [{ label: "Alternance Mission 1", url: "/Portfolio-BUT/projects/alternance" }]
            },
        ]
    },
    {
        num: 5,
        nom: "Collaborer",
        niveau: "Niveau 3 — Manager une équipe informatique",
        color: "green",
        badgeClass: "bg-green-600 dark:bg-green-700",
        borderClass: "border-green-400",
        acs: [
            {
                id: "AC35.01",
                titre: "Organiser et partager une veille numérique",
                niveau: niveaux.enCours,
                description: "En alternance, présentation régulière de design patterns à l'équipe chaque vendredi (Factory, Prototype, Iterator). Partage structuré des connaissances techniques avec démonstration d'implémentation dans le code existant.",
                projets: [{ label: "Alternance Mission 1", url: "/Portfolio-BUT/projects/alternance" }]
            },
            {
                id: "AC35.02",
                titre: "Identifier les enjeux de l'économie de l'innovation numérique",
                niveau: niveaux.enCours,
                description: "Formation SMSI MOOC ANSSI sur les enjeux de la sécurité et de la gouvernance numérique. Compréhension des problématiques de conformité et de protection des données dans un contexte professionnel.",
                projets: [{ label: "Alternance Mission 1", url: "/Portfolio-BUT/projects/alternance" }]
            },
            {
                id: "AC35.03",
                titre: "Guider la conduite du changement informatique au sein d'une organisation",
                niveau: niveaux.enCours,
                description: "Participation à l'introduction de nouvelles normes de code dans l'équipe (remplacement des stdClass, nouveaux namespaces, documentation automatisée). Accompagnement de l'équipe dans l'adoption de ces pratiques.",
                projets: [{ label: "Alternance Mission 1", url: "/Portfolio-BUT/projects/alternance" }]
            },
            {
                id: "AC35.04",
                titre: "Accompagner le management de projet informatique",
                niveau: niveaux.acquis,
                description: "En tant que Scrum Master sur la SAE3A, organisation des sprints, facilitation des daily meetings, gestion des blocages et maintien de la dynamique d'équipe. Application concrète des pratiques agiles sur un projet universitaire.",
                projets: [{ label: "SAE3A", url: "/Portfolio-BUT/projects/SAE3A" }]
            },
        ]
    },
];

const colorMap: Record<string, string> = {
    orange: 'text-orange-600 dark:text-orange-400',
    blue:   'text-blue-600 dark:text-blue-400',
    cyan:   'text-cyan-600 dark:text-cyan-400',
    purple: 'text-purple-600 dark:text-purple-400',
    green:  'text-green-600 dark:text-green-400',
};
---

<Layout>
    <main class="min-h-screen border-2 border-gray-600 rounded-2xl">

        <!-- Hero -->
        <section class="relative py-20 px-4 text-center">
            <div class="relative mx-auto rounded-2xl shadow-lg pt-5 pb-5 dark:bg-gray-800">
                <div class="text-6xl mb-6">📚</div>
                <h1 class="font-monospace text-4xl lg:text-6xl text-gray-900 dark:text-gray-100 mb-6">
                    Apprentissages <span class="text-red-500 dark:text-red-400">Critiques</span>
                </h1>
                <p class="text-xl text-gray-700 dark:text-gray-300 max-w-2xl mx-auto leading-relaxed">
                    Compétences BUT Informatique — Niveau 3. Bilan de mes acquisitions à travers mes projets universitaires et mon alternance.
                </p>
            </div>
        </section>

        <!-- Légende -->
        <section class="py-6 px-4">
            <div class="max-w-3xl mx-auto">
                <div class="bg-white dark:bg-gray-800 p-5 rounded-2xl shadow flex flex-wrap gap-6 justify-center">
                    <div class="flex items-center gap-2">
                        <span class="w-3 h-3 rounded-full bg-green-500"></span>
                        <span class="text-sm text-gray-700 dark:text-gray-300 font-medium">Acquis — sait faire</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="w-3 h-3 rounded-full bg-yellow-500"></span>
                        <span class="text-sm text-gray-700 dark:text-gray-300 font-medium">En cours d'acquisition</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="w-3 h-3 rounded-full bg-red-400"></span>
                        <span class="text-sm text-gray-700 dark:text-gray-300 font-medium">Débutant — ne sait pas encore faire</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Les 5 compétences -->
        {competences.map((comp) => (
            <section class="py-14 px-4">
                <div class="max-w-6xl mx-auto">
                    <!-- Header compétence -->
                    <div class="text-center mb-12">
                        <span class={`inline-block ${comp.badgeClass} text-white px-4 py-2 rounded-full text-sm font-medium mb-4`}>
                            Compétence {comp.num}
                        </span>
                        <h2 class={`font-monospace text-3xl lg:text-4xl text-gray-900 dark:text-gray-100 mb-3 ${colorMap[comp.color]}`}>
                            {comp.nom}
                        </h2>
                        <p class="text-gray-500 dark:text-gray-400 text-base max-w-2xl mx-auto">{comp.niveau}</p>
                        <div class="w-20 h-1 bg-gradient-to-r from-gray-300 to-gray-500 mx-auto rounded-full mt-4"></div>
                    </div>

                    <!-- Cards AC -->
                    <div class={`grid gap-6 ${comp.acs.length === 2 ? 'md:grid-cols-2 max-w-3xl mx-auto' : 'md:grid-cols-2 lg:grid-cols-3'}`}>
                        {comp.acs.map((ac) => (
                            <div class={`bg-white dark:bg-gray-800 rounded-2xl shadow-lg p-7 border-t-4 ${comp.borderClass} relative hover:shadow-xl transition-all duration-300`}>
                                <!-- Badge niveau -->
                                <div class="absolute -top-3 right-4">
                                    <span class={`${ac.niveau.color} text-white text-xs font-semibold px-3 py-1 rounded-full shadow`}>
                                        {ac.niveau.label}
                                    </span>
                                </div>

                                <p class="text-xs font-mono text-gray-400 dark:text-gray-500 mb-2">{ac.id}</p>
                                <h3 class={`text-base font-bold mb-3 ${colorMap[comp.color]}`}>{ac.titre}</h3>
                                <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed mb-5">{ac.description}</p>

                                {ac.projets.length > 0 && (
                                    <div class="flex flex-wrap gap-2">
                                        {ac.projets.map((p) => (
                                            <a
                                                href={p.url}
                                                class={`text-xs font-medium px-3 py-1.5 rounded-full border ${ac.niveau.bg} ${ac.niveau.border} ${ac.niveau.text} hover:opacity-80 transition-opacity`}
                                            >
                                                {p.label} →
                                            </a>
                                        ))}
                                    </div>
                                )}
                                {ac.projets.length === 0 && (
                                    <p class="text-xs text-gray-400 dark:text-gray-500 italic">Aucun projet dédié pour l'instant</p>
                                )}
                            </div>
                        ))}
                    </div>
                </div>
            </section>
        ))}

        <Contact />
        <BackToTop />
    </main>
</Layout>
